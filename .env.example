# MCP Wrangler environment configuration
# Copy this file to .env and update the values before running.

# Encryption key for stored credentials (generate with: openssl rand -hex 32)
MCP_WRANGLER_ENCRYPTION_KEY=changeme

# Session secret for web UI cookies (generate with: openssl rand -hex 32)
MCP_WRANGLER_SESSION_SECRET=changeme

# Default admin password (only used on first run to create the admin user)
MCP_WRANGLER_ADMIN_PASSWORD=changeme

# Database path (inside the container)
MCP_WRANGLER_DB_PATH=/data/mcp-wrangler.db
